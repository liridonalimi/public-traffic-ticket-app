# Copy outside source control, replace every placeholder, and protect every role-token file.
BUSPAY_STAGING_BASE_URL=https://staging.buspay.example
BUSPAY_IMAGE=registry.example/buspay-sync@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
BUSPAY_EDGE_NETWORK=buspay-staging-edge
BUSPAY_DEVICE_TOKEN_FILE=/run/operator-secrets/buspay-staging-device-token
BUSPAY_REPORT_TOKEN_FILE=/run/operator-secrets/buspay-staging-report-token
BUSPAY_CATALOG_TOKEN_FILE=/run/operator-secrets/buspay-staging-catalog-token
BUSPAY_AUDIT_TOKEN_FILE=/run/operator-secrets/buspay-staging-audit-token
BUSPAY_STAGING_REGION=replace-with-region
BUSPAY_OPERATIONS_OWNER=replace-with-operations-owner
BUSPAY_SECURITY_OWNER=replace-with-security-owner
BUSPAY_BACKUP_OWNER=replace-with-backup-owner
BUSPAY_BACKUP_RETENTION_DAYS=14
BUSPAY_WEB_WORKERS=2
BUSPAY_WEB_THREADS=4
